NUXT_PORT=3000
NUXT_ANTHROPIC_API_KEY=your-anthropic-api-key-here
NUXT_ANTHROPIC_MODEL=claude-sonnet-4-6
# Optional: overrides the default qualification prompt defined in server/prompts/qualification.ts
NUXT_ANTHROPIC_SYSTEM_PROMPT=

# GitLab OAuth — create an application in GitLab Admin > Applications
# Callback URL: http://localhost:3000/api/auth/callback/gitlab
# Scopes: read_user, read_api
# Generate NEXTAUTH_SECRET with: openssl rand -base64 32
NEXTAUTH_SECRET=your-random-secret-here
NEXTAUTH_URL=http://localhost:3000
NUXT_GITLAB_CLIENT_ID=your-gitlab-oauth-app-client-id
NUXT_GITLAB_CLIENT_SECRET=your-gitlab-oauth-app-client-secret
NUXT_GITLAB_URL=http://localhost
# En Docker, le container chat doit joindre GitLab via son hostname réseau.
# Défini dans docker-compose.yml (environment) plutôt qu'ici : NUXT_GITLAB_INTERNAL_URL=http://gitlab
