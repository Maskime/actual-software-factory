{
  "name": "@factory/root",
  "private": true,
  "workspaces": [
    "mcp/*",
    "apps/*"
  ],
  "scripts": {
    "build": "npm run build --workspaces --if-present",
    "lint": "npm run lint --workspaces --if-present",
    "typecheck": "npx nuxi prepare --cwd apps/chat && npm run lint --workspaces --if-present && npm run typecheck -w @factory/chat",
    "test": "vitest run",
    "test:coverage": "vitest run --coverage",
    "dev:chat": "npm run dev --workspace=apps/chat"
  },
  "devDependencies": {
    "@types/node": "^22.10.7",
    "@vitest/coverage-v8": "^2.0.0",
    "tsx": "^4.19.2",
    "typescript": "^5.8.0",
    "vitest": "^2.0.0"
  },
  "optionalDependencies": {
    "next-auth": "^4.21.1"
  }
}
