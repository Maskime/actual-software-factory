# =============================================================================
# GitLab CE (US-01)
# =============================================================================

# URL d'accès à GitLab (ex: http://localhost ou http://gitlab.example.com)
GITLAB_EXTERNAL_URL=http://localhost

# Mot de passe root GitLab — minimum 8 caractères, pas de guillemets simples
# En cas de premier démarrage sans prise en compte du mot de passe :
#   docker exec gitlab cat /etc/gitlab/initial_root_password
#   (fichier supprimé automatiquement 24h après le premier démarrage)
GITLAB_ROOT_PASSWORD=change_me_strong_password

# =============================================================================
# GitLab CI — projet de test (US-02)
# =============================================================================

# Nom du projet de test créé par infrastructure/scripts/setup-gitlab.sh
GITLAB_TEST_PROJECT_NAME=factory-test

# =============================================================================
# SonarQube Community Edition (US-03)
# =============================================================================

# URL d'accès à SonarQube (ex: http://localhost:9000)
SONARQUBE_EXTERNAL_URL=http://localhost:9000

# Mot de passe admin SonarQube (remplace le mot de passe par défaut "admin")
# Minimum 12 caractères recommandés
SONARQUBE_ADMIN_PASSWORD=change_me_strong_password

# Mot de passe PostgreSQL pour la base SonarQube (usage interne inter-conteneurs)
SONARQUBE_DB_PASSWORD=change_me_db_password

# Prérequis hôte (Elasticsearch intégré) — à exécuter une fois sur l'hôte :
#   sudo sysctl -w vm.max_map_count=524288
#   echo 'vm.max_map_count=524288' | sudo tee /etc/sysctl.d/sonarqube.conf
# Le script setup-sonarqube.sh vérifie cette valeur et bloque si insuffisante.

# =============================================================================
# SonarQube — projet de test (US-04)
# =============================================================================

# Clé du projet de test créé par infrastructure/scripts/setup-sonarqube-analysis.sh
SONARQUBE_TEST_PROJECT_KEY=factory-test

# =============================================================================
# Temporal — Orchestrateur de workflows (US-05)
# =============================================================================

# URL d'accès à l'UI Temporal (ex: http://localhost:8080)
TEMPORAL_EXTERNAL_URL=http://localhost:8080

# Mot de passe PostgreSQL pour la base Temporal (usage interne inter-conteneurs)
TEMPORAL_DB_PASSWORD=change_me_temporal_db_password

# =============================================================================
# Secrets transversaux — agents LLM et intégrations (US-07 / requis dès EPIC-02)
# =============================================================================

# Clé API Anthropic — utilisée par tous les agents LLM de la factory
# Obtenir sur https://console.anthropic.com/settings/keys
ANTHROPIC_API_KEY=

# Token d'accès personnel GitLab — utilisé par les agents pour créer épics/issues/MR
# Portée minimale : api (read_api suffit pour la lecture, api pour l'écriture)
# Créer sur : GitLab → Préférences → Access Tokens
GITLAB_API_TOKEN=

# URL de base de l'API GitLab — utilisée par le serveur MCP GitLab (EPIC-02)
# Dérivée de GITLAB_EXTERNAL_URL en ajoutant /api/v4
GITLAB_API_URL=http://localhost/api/v4

# Token utilisateur SonarQube — utilisé par l'agent d'analyse statique (EPIC-09)
# Créer sur : SonarQube → Mon compte → Sécurité → Générer un token
SONARQUBE_AGENT_TOKEN=

# Clé du projet SonarQube principal — utilisée par le worker d'analyse statique (EPIC-09)
# Visible dans : SonarQube → Projet → Informations du projet → Clé
SONARQUBE_PROJECT_KEY=root_software-factory_c0a1453c-752b-438e-b86b-311ac2555bb4

# URLs externes des serveurs MCP — pour les tests round-trip depuis l'hôte (make test-mcp)
# Endpoint /mcp confirmé pour les trois serveurs (voir doc SonarSource + code source MCP GitLab/Temporal)
# Depuis un conteneur (agent-worker), utiliser les variables MCP_*_INTERNAL_URL dans docker-compose.yml
MCP_GITLAB_URL=http://localhost:3001/mcp
MCP_TEMPORAL_URL=http://localhost:3003/mcp
MCP_SONARQUBE_URL=http://localhost:3002/mcp

# Secret HMAC pour valider les webhooks GitLab → Temporal (EPIC-04)
# Générer avec : openssl rand -hex 32
GITLAB_WEBHOOK_SECRET=

# =============================================================================
# Observabilité — Grafana + Loki (centralisation des logs)
# =============================================================================

# Port hôte pour Grafana UI (http://localhost:<port>)
# Port 3100 est libre : Loki n'est pas exposé sur l'hôte (expose: interne uniquement)
GRAFANA_PORT=3100

# Identifiants Grafana admin (UI et API provisioning)
GRAFANA_ADMIN_USER=admin
GRAFANA_ADMIN_PASSWORD=change_me_grafana_password

# =============================================================================
# PlantUML Server — génération de diagrammes (http://localhost:<port>)
# =============================================================================

# Port hôte pour le serveur PlantUML (8080 déjà pris par temporal-ui)
PLANTUML_PORT=8081

# =============================================================================
# Alerting — Pipelines bloqués (EPIC-10 / US-4)
# =============================================================================

# Durée (minutes) au-delà de laquelle un pipeline Running est considéré bloqué (défaut : 60)
PIPELINE_TIMEOUT_MINUTES=60

# URL du webhook HTTP à notifier par POST JSON — vide = alerting désactivé
ALERT_WEBHOOK_URL=

# =============================================================================
# Factory DB — PostgreSQL 16 + pgvector (EPIC-11 / RAG)
# =============================================================================
FACTORY_DB_PASSWORD=change_me_factory_db_password
