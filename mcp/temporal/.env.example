# Temporal server gRPC address (host:port)
# Inside Docker network: temporal:7233
# Local development: localhost:7233
TEMPORAL_ADDRESS=localhost:7233

# Temporal namespace to operate on.
# "default" is created automatically by temporalio/auto-setup.
# Use a dedicated namespace (e.g. "factory") for production isolation.
TEMPORAL_NAMESPACE=default

# MCP HTTP server port
PORT=3000

# --- mTLS (optional) ---
# Paths to client certificate and key files (PEM format).
# Enables mTLS if both are set. Takes precedence over TEMPORAL_API_KEY.
# TEMPORAL_TLS_CERT_PATH=/run/secrets/temporal-client.crt
# TEMPORAL_TLS_KEY_PATH=/run/secrets/temporal-client.key

# --- Temporal Cloud API key (optional) ---
# Enables API-key auth + TLS for Temporal Cloud.
# TEMPORAL_API_KEY=your-cloud-api-key

# --- GitLab API (required for pre-trigger guard) ---
# Used to check issue labels/state before starting a workflow.
# Omitting these disables the duplicate-trigger guard (warning logged on startup).
GITLAB_API_URL=http://localhost/api/v4
GITLAB_API_TOKEN=
