# Agent Worker — variables d'environnement
# En production : toutes les variables sont injectées via infrastructure/docker-compose.yml
# En développement local (tsx src/worker.ts) : copier ce fichier en .env et renseigner les valeurs

# =============================================================================
# Temporal
# =============================================================================
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=factory
TEMPORAL_TASK_QUEUE=factory-agents

# =============================================================================
# Anthropic (LLM) — requis par tous les agents EPIC-05 à EPIC-09
# À renseigner également dans infrastructure/.env avant docker compose up
# =============================================================================
ANTHROPIC_API_KEY=

# =============================================================================
# GitLab
# =============================================================================
GITLAB_API_URL=http://gitlab/api/v4
GITLAB_API_TOKEN=

# =============================================================================
# MCP servers (HTTP transport)
# =============================================================================
MCP_GITLAB_URL=http://mcp-gitlab:3000/mcp
MCP_TEMPORAL_URL=http://mcp-temporal:3000/mcp
MCP_SONARQUBE_URL=http://mcp-sonarqube:3000/mcp
