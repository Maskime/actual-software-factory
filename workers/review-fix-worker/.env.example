# Review Fix Worker — variables d'environnement
# En production : toutes les variables sont injectées via infrastructure/docker-compose.yml
# En développement local (tsx src/worker.ts) : copier ce fichier en .env et renseigner les valeurs

# =============================================================================
# Temporal
# =============================================================================
TEMPORAL_ADDRESS=temporal:7233
TEMPORAL_NAMESPACE=factory
TEMPORAL_TASK_QUEUE=review-fix-queue

# =============================================================================
# Anthropic (LLM) — requis pour la correction automatique
# À renseigner également dans infrastructure/.env avant docker compose up
# =============================================================================
ANTHROPIC_API_KEY=
ANTHROPIC_MODEL=claude-sonnet-4-6

# =============================================================================
# GitLab
# =============================================================================
GITLAB_API_INTERNAL_URL=http://gitlab/api/v4
GITLAB_API_TOKEN=

# =============================================================================
# MCP servers (HTTP transport)
# =============================================================================
MCP_GITLAB_INTERNAL_URL=http://mcp-gitlab:3000/mcp

# =============================================================================
# Healthcheck HTTP interne — ne pas exposer via ports:
# =============================================================================
HEALTH_PORT=9093
